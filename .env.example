# CodeForge AI — Environment Variables
# Copy this file to .env.local and fill in your values
# For Vercel: add these in Project Settings → Environment Variables

# ── Required: Database ──
# SQLite for local dev (default):
DATABASE_URL="file:./dev.db"

# PostgreSQL for production (Vercel, Railway, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ── Required: LLM API Keys (at least one) ──
# Primary provider key
OPENAI_API_KEY=

# Optional: Additional provider keys
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# ── Required: Auth Secret ──
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Optional: Z.ai SDK ──
# Z_AI_API_KEY=

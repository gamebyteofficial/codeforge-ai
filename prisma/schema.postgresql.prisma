// ── Prisma Schema for PostgreSQL (Cloud/Vercel) ──
// Replace the contents of prisma/schema.prisma with this file
// when deploying to Vercel, Railway, Render, or any cloud platform.
//
// Also set DATABASE_URL env var to your PostgreSQL connection string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  path        String   @default("/")
  language    String   @default("typescript")
  framework   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  conversations Conversation[]
  files       File[]
  tasks       Task[]
  memories    Memory[]
}

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model Message {
  id             String   @id @default(cuid())
  role           String
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tokens         Int?
  model          String?
  createdAt      DateTime @default(now())
}

model File {
  id        String   @id @default(cuid())
  name      String
  path      String
  content   String   @default("")
  language  String?
  isFolder  Boolean  @default(false)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  agent       String?
  result      String?
  progress    Int      @default(0)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Memory {
  id        String   @id @default(cuid())
  type      String   @default("short_term")
  category  String?
  key       String
  value     String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
